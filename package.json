{
  "name": "cfdi-kit",
  "version": "1.1.1",
  "description": "Librería minimalista para parsear y validar CFDIs (SAT México) en TypeScript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CarlosUriass/cfdi-kit.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/CarlosUriass/cfdi-kit/issues"
  },
  "homepage": "https://github.com/CarlosUriass/cfdi-kit#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup index.ts --format cjs,esm --dts --clean",
    "dev": "tsup index.ts --format cjs,esm --watch --dts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cfdi",
    "cfdi 4.0",
    "sat",
    "mexico",
    "facturacion",
    "factura electronica",
    "xml",
    "parser",
    "validacion",
    "timbre fiscal",
    "nexus",
    "contabilidad"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.5"
  }
}